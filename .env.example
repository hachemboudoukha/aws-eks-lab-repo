# AWS Configuration
AWS_ACCOUNT_ID=123456789012
AWS_DEFAULT_REGION=us-east-1
AWS_PROFILE=default

# ECR Configuration
IMAGE_REPO_NAME=my-app-repo
DOCKER_REGISTRY_URI=${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_DEFAULT_REGION}.amazonaws.com

# EKS Configuration
EKS_CLUSTER_NAME=my-eks-cluster
EKS_CLUSTER_REGION=${AWS_DEFAULT_REGION}

# Application Configuration
APP_DOMAIN=myapp.example.com
APP_ENVIRONMENT=production
PORT=8000

# Kubernetes Ingress Configuration
ALB_SECURITY_GROUP_ID=sg-xxxxxxxxx
PUBLIC_SUBNET_IDS=subnet-xxxxx,subnet-xxxxx

# CodePipeline Configuration
CODEPIPELINE_NAME=my-app-pipeline
CODEBUILD_PROJECT_NAME=my-app-build

# Terraform Configuration
TERRAFORM_VERSION=1.0
